// KEYBOARD
// ═══════════════════════════════════════════════════════════
const keysDown = new Set();
const MOVE_KEYS = new Set(['ArrowUp','ArrowDown','ArrowLeft','ArrowRight','KeyZ','KeyX']);

// Orbit presets (scale with scene size)
const OT_FULL  = new THREE.Vector3(CX, CY, CZ);
const OT_MID   = new THREE.Vector3(NDIM>=7?FLOOR_SPAN/2:CX, CY, NDIM>=7?FLOOR_SPAN/2:CZ);
const OT_SMALL = new THREE.Vector3(CUBE_SPAN/2, CY*0.5, CUBE_SPAN/2);

window.addEventListener('keydown', e => {
  if(MOVE_KEYS.has(e.code)) e.preventDefault();
  keysDown.add(e.code);
  const setOrbit = on => {
    controls.autoRotate=on;
    const el=document.getElementById('h-orbit');
    el.textContent=on?'ON':'OFF'; el.style.color=on?'#3af':'#a33';
  };
  switch(e.code){
    case 'Space': e.preventDefault(); // falls through
    case 'KeyR': setOrbit(!controls.autoRotate); break;
    case 'KeyT': controls.target.copy(OT_FULL);
      camera.position.set(CX-MAX_EXT*0.4,CY+MAX_EXT*0.32,CZ+MAX_EXT*0.62);
      setOrbit(true); break;
    case 'KeyY': controls.target.copy(OT_MID);
      camera.position.set(OT_MID.x-MAX_EXT*0.1,OT_MID.y+MAX_EXT*0.15,OT_MID.z+MAX_EXT*0.3);
      setOrbit(true); break;
    case 'KeyU': controls.target.copy(OT_SMALL);
      camera.position.set(OT_SMALL.x-8,OT_SMALL.y+15,OT_SMALL.z+30);
      setOrbit(true); break;
    case 'Digit1': camera.position.set(CX,CY+MAX_EXT*0.8,CZ+5); controls.target.copy(OT_FULL); break;
    case 'Digit2': resetCam(); break;
    case 'Digit3': camera.position.set(OT_MID.x,OT_MID.y+MAX_EXT*0.2,OT_MID.z+MAX_EXT*0.35);
      controls.target.copy(OT_MID); break;
    case 'Escape': clearHighlights(); break;
  }
});
window.addEventListener('keyup', e=>keysDown.delete(e.code));

const _fwd=new THREE.Vector3(),_right=new THREE.Vector3(),_delta=new THREE.Vector3();
function handleMovement(){
  if(keysDown.size===0) return;
  const speed=Math.max(0.2,camera.position.distanceTo(controls.target)*0.025);
  camera.getWorldDirection(_fwd); _fwd.y=0; _fwd.normalize();
  _right.crossVectors(_fwd,camera.up).normalize();
  _delta.set(0,0,0);
  if(keysDown.has('ArrowUp'))    _delta.addScaledVector(_fwd,   speed);
  if(keysDown.has('ArrowDown'))  _delta.addScaledVector(_fwd,  -speed);
  if(keysDown.has('ArrowLeft'))  _delta.addScaledVector(_right,-speed);
  if(keysDown.has('ArrowRight')) _delta.addScaledVector(_right, speed);
  if(keysDown.has('KeyZ'))       _delta.y+=speed;
  if(keysDown.has('KeyX'))       _delta.y-=speed;
  if(_delta.lengthSq()>0){camera.position.add(_delta);controls.target.add(_delta);}
}

// ═══════════════════════════════════════════════════════════
// GAMEPAD  (Xbox / standard gamepad API)
// ═══════════════════════════════════════════════════════════
const GP_DEADZONE = 0.12;

// Three speed tiers — orbit is angular (rad/frame), fly is world-units/frame
// at unit distance; scaled by actual camera distance at runtime.
const GP_SPEEDS = [
  { name: 'SLOW',   orbit: 0.007, fly: 0.006 },
  { name: 'NORMAL', orbit: 0.022, fly: 0.018 },
  { name: 'FAST',   orbit: 0.065, fly: 0.055 },
];
let gpSpeedIdx  = 1;   // start at NORMAL
let gpConnected = false;
let gpAWasDown  = false;

// Re-use Three.js objects to avoid per-frame allocations
const _gpSph = new THREE.Spherical();
const _gpOff = new THREE.Vector3();
const _gpDir = new THREE.Vector3();

function deadzone(v) {
  // Apply deadzone then rescale so the full range is still 0→1
  return Math.abs(v) < GP_DEADZONE
    ? 0
    : (v - Math.sign(v) * GP_DEADZONE) / (1 - GP_DEADZONE);
}

function handleGamepad() {
  // navigator.getGamepads() returns a live list; must re-query every frame
  const pads = navigator.getGamepads ? navigator.getGamepads() : [];
  let pad = null;
  for (const p of pads) { if (p && p.connected) { pad = p; break; } }

  // ── connection state → HUD ───────────────────────────────
  if (!!pad !== gpConnected) {
    gpConnected = !!pad;
    const row = document.getElementById('gp-row');
    const el  = document.getElementById('h-gp');
    if (gpConnected) {
      row.style.display = ''; el.style.display = '';
    } else {
      row.style.display = 'none'; el.style.display = 'none';
      gpAWasDown = false;
      return;
    }
  }
  if (!pad) return;

  const speed    = GP_SPEEDS[gpSpeedIdx];
  const camDist  = camera.position.distanceTo(controls.target);
  // Fly speed scales with distance so it feels consistent at any zoom level
  const flySpeed = speed.fly * Math.max(0.01, camDist * 0.08);

  // ── Left Stick → orbit around target ────────────────────
  // axes[0] = LS X  (-1=left, +1=right)
  // axes[1] = LS Y  (-1=up,   +1=down )
  const lx = deadzone(pad.axes[0] ?? 0);
  const ly = deadzone(pad.axes[1] ?? 0);

  if (lx !== 0 || ly !== 0) {
    _gpOff.copy(camera.position).sub(controls.target);
    _gpSph.setFromVector3(_gpOff);

    // theta = azimuth (left/right), phi = polar (up/down)
    _gpSph.theta -= lx * speed.orbit;
    _gpSph.phi   += ly * speed.orbit;
    // Clamp so camera never flips past the poles
    _gpSph.phi = Math.max(0.04, Math.min(Math.PI - 0.04, _gpSph.phi));

    _gpOff.setFromSpherical(_gpSph);
    camera.position.copy(controls.target).add(_gpOff);
    controls.update();

    // Disable auto-rotate while the user is manually orbiting
    if (controls.autoRotate) {
      controls.autoRotate = false;
      const el = document.getElementById('h-orbit');
      el.textContent = 'OFF'; el.style.color = '#a33';
    }
  }

  // ── RB (buttons[5]) = fly forward ───────────────────────
  // ── RT (buttons[7]) = fly backward  (analog trigger → .value)
  const rbPressed = pad.buttons[5]?.pressed ? 1 : 0;
  const rtValue   = pad.buttons[7]?.value   // analog 0→1
    ?? (pad.buttons[7]?.pressed ? 1 : 0);

  const flyAmount = (rbPressed - rtValue) * flySpeed;
  if (Math.abs(flyAmount) > 0.0001) {
    camera.getWorldDirection(_gpDir);
    camera.position.addScaledVector(_gpDir,    flyAmount);
    controls.target.addScaledVector(_gpDir,    flyAmount);
    controls.update();
  }

  // ── A (buttons[0]) → cycle speed on rising edge ─────────
  const aDown = !!pad.buttons[0]?.pressed;
  if (aDown && !gpAWasDown) {
    gpSpeedIdx = (gpSpeedIdx + 1) % GP_SPEEDS.length;
    const el = document.getElementById('h-gp');
    el.textContent = GP_SPEEDS[gpSpeedIdx].name;
    // Brief flash so user notices the change
    el.style.color = '#ff0';
    setTimeout(() => { el.style.color = '#0df'; }, 400);
    dirty = true;
  }
  gpAWasDown = aDown;

  // Update HUD speed label every frame (cheap)
  document.getElementById('h-gp').textContent = GP_SPEEDS[gpSpeedIdx].name;
}

// Show/hide gamepad row on connect/disconnect events
window.addEventListener('gamepadconnected', e => {
  console.log('[gamepad] connected:', e.gamepad.id);
  gpConnected = true;
  document.getElementById('gp-row').style.display = '';
  document.getElementById('h-gp').style.display   = '';
  document.getElementById('h-gp').textContent     = GP_SPEEDS[gpSpeedIdx].name;
  document.getElementById('h-gp').style.color     = '#0df';
});
window.addEventListener('gamepaddisconnected', e => {
  console.log('[gamepad] disconnected:', e.gamepad.id);
  gpConnected = false;
  document.getElementById('gp-row').style.display = 'none';
  document.getElementById('h-gp').style.display   = 'none';
});

// ═══════════════════════════════════════════════════════════
// RENDER LOOP
// ═══════════════════════════════════════════════════════════
const DRAW_INTERVAL=1000/DRAW_FPS;
let lastDraw=0;
function animate(now){
  requestAnimationFrame(animate);
  handleMovement();
  handleGamepad();   // runs every frame; no-ops if no controller connected
  controls.update();
  if(now-lastDraw>=DRAW_INTERVAL){lastDraw=now;rebuildBuffers();}
  // Keep rebuilding while trails or highlights are live
  if(selectedPieceKey || trailBuf.length>0) dirty=true;
  renderer.render(scene,camera);
}

// ═══════════════════════════════════════════════════════════
// INIT
// ═══════════════════════════════════════════════════════════
(async()=>{
  const status=document.getElementById('status');

  status.textContent='⬤ building geometry…';
  initPiecePoints();
  buildWireframes();

  if (NDIM === 2) {
    // For 2D, add file/rank labels
    function makeLabel2D(text, color='rgba(80,140,240,0.85)'){
      const cv=document.createElement('canvas');cv.width=32;cv.height=32;
      const ctx=cv.getContext('2d');
      ctx.font='bold 18px "Courier New",monospace'; ctx.fillStyle=color;
      ctx.textAlign='center'; ctx.textBaseline='middle'; ctx.fillText(text,16,16);
      const tex=new THREE.CanvasTexture(cv);tex.needsUpdate=true;
      const sp=new THREE.Sprite(new THREE.SpriteMaterial({map:tex,transparent:true,depthWrite:false}));
      sp.scale.set(1.2,1.2,1); return sp;
    }
    const files='abcdefgh',ranks='12345678';
    for(let i=0;i<8;i++){
      const fs=makeLabel2D(files[i]); fs.position.set(i+0.5,0.25,8.8); scene.add(fs);
      const rs=makeLabel2D(ranks[i]); rs.position.set(-0.9,0.25,i+0.5); scene.add(rs);
    }
  }

  status.textContent=`⬤ building ${NP}-player board…`;
  board=await buildBoard(); dirty=true; rebuildBuffers();

  status.textContent=`⬤ starting ${NDIM}D game…`;
  try {
    const r=await fetch(`${ENGINE}/new_game`,{
      method:'POST',headers:{'Content-Type':'application/json'},
      body:JSON.stringify({dims:NDIM,players:NP,game_id:GAME_ID}),
      signal:AbortSignal.timeout(5000),
    });
    const d=await r.json();
    if(d.ok){
      board=await buildBoard(); alive=new Array(NP).fill(true);
      turnNum=0;capCount=0;activePid=0;dirty=true;
      status.textContent=`⬤ ${NDIM}D game ready!`;
    }
  } catch(e){
    status.textContent='⬤ engine not found — start engine_py.py 8769';
    status.style.color='#a33';
    await new Promise(r=>setTimeout(r,2000));
  }

  // Download button
  document.getElementById('dl-log').addEventListener('click',()=>{
    const lines=['turn,player,piece,capture,captured_piece,captured_player'];
    fullLog.forEach((m,i)=>{
      lines.push([m.turn??i+1,`P${m.pid+1}`,m.sym,m.cap?1:0,m.cap?m.capSym:'',m.capPid!=null?`P${m.capPid+1}`:''].join(','));
    });
    const blob=new Blob([lines.join('\n')],{type:'text/csv'});
    const a=document.createElement('a');
    a.href=URL.createObjectURL(blob);
    a.download=`${NDIM}d-chess-t${fullLog.length}-${Date.now()}.csv`;
    a.click(); URL.revokeObjectURL(a.href);
  });

  gameLoop();
  requestAnimationFrame(animate);
  addCubeGrid();   // async background task for large scenes
})();
</script>

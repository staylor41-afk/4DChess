<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>ND Chess — Visualizer</title>
<style>
* { margin:0; padding:0; box-sizing:border-box; }
body { background:#000; overflow:hidden; font-family:'Courier New',monospace; }

#hud {
  position:fixed; top:14px; left:16px;
  font-size:11px; line-height:2.0; color:#3a4a6a;
  pointer-events:none; text-transform:uppercase; letter-spacing:.05em;
  text-shadow:0 0 8px #0008;
}
.val  { color:#0df; font-weight:bold; }
.cap  { color:#fa0; font-weight:bold; }
.pid  { font-weight:bold; }
.dim  { color:#a0f; font-size:13px; font-weight:bold; }

#legend {
  position:fixed; top:14px; right:16px;
  font-size:10px; line-height:2.0; color:#2a3858;
  text-align:right; pointer-events:none;
}
#keys {
  position:fixed; bottom:14px; left:16px;
  font-size:10px; line-height:1.8; color:#1e2c44;
  pointer-events:none;
}
#status {
  position:fixed; bottom:14px; right:16px;
  font-size:10px; line-height:1.8; color:#1e2c44;
  text-align:right; pointer-events:none;
}
#movelog {
  position:fixed; right:16px; bottom:48px;
  width:230px; max-height:340px; overflow:hidden;
  font-size:10px; line-height:1.7; font-family:'Courier New',monospace;
  pointer-events:none; text-align:right;
  mask-image:linear-gradient(to bottom, transparent 0%, black 18%);
  -webkit-mask-image:linear-gradient(to bottom, transparent 0%, black 18%);
}
#dl-log {
  position:fixed; bottom:14px; left:50%; transform:translateX(-50%);
  background:#050d1c; border:1px solid #1e3868; color:#3a7;
  padding:4px 14px; font-size:10px; font-family:'Courier New',monospace;
  cursor:pointer; letter-spacing:.08em; z-index:10;
  transition: border-color .2s, color .2s;
}
#dl-log:hover { border-color:#3a7; color:#6fd; }

/* human-turn banner */
#human-banner {
  display:none;
  position:fixed; top:50%; left:50%; transform:translate(-50%,-50%);
  background:rgba(0,0,0,0.82); border:1px solid #3a7;
  padding:18px 36px; text-align:center;
  font-size:13px; color:#3af; pointer-events:none;
  letter-spacing:.1em; z-index:20;
}
#human-banner.active { display:block; }

/* back-to-menu */
#menu-btn {
  position:fixed; top:14px; left:50%; transform:translateX(-50%);

  cursor:pointer; letter-spacing:.08em; z-index:10;
  transition: border-color .2s, color .2s;
}
#menu-btn:hover { border-color:#4060a0; color:#5080cc; }
</style>
</head>
<body>

<div id="hud">
  <span class="dim" id="h-title">ND CHESS</span><br>
  <span style="color:#334">TURN ···</span> <span class="val" id="h-turn">—</span><br>
  <span style="color:#334">PLAYER ·</span> <span class="pid" id="h-pid">—</span><br>
  <span style="color:#334">PIECES ·</span> <span class="val" id="h-pcs">—</span><br>
  <span style="color:#334">ALIVE ··</span> <span class="val" id="h-alive">—</span><span style="color:#334" id="h-np-label"></span><br>
  <span style="color:#334">CAPTURES</span> <span class="cap"  id="h-caps">0</span><br>
  <span style="color:#334">T/SEC ··</span> <span class="val" id="h-tps">—</span><br>
  <span style="color:#334">ORBIT ··</span> <span class="val" id="h-orbit" style="color:#3af">ON</span><br>
  <span style="color:#334" id="gp-row" style="display:none">GAMEPAD ·</span><span class="val" id="h-gp" style="display:none"></span>

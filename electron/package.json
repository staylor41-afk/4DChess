{
  "name": "nd-chess",
  "version": "47.0.0",
  "description": "ND Chess — 2D through 8D, 2 to 128 players — by Samuel M G Taylor",
  "author": "Samuel M G Taylor",
  "main": "main.js",
  "scripts": {
    "start":       "electron . --enable-logging",
    "build-win":   "electron-builder --win",
    "build-mac":   "electron-builder --mac",
    "build-linux": "electron-builder --linux",
    "build-all":   "electron-builder --mac --win --linux"
  },
  "build": {
    "appId": "com.samueltaylor.ndchess",
    "productName": "ND Chess",
    "files": [
      "main.js",
      "preload.js"
    ],
    "extraResources": [
      { "from": "../start.html",        "to": "start.html"        },
      { "from": "../chess-classic.html","to": "chess-classic.html"},
      { "from": "../visualizer.html",   "to": "visualizer.html"   },
      { "from": "../engine_py.py",      "to": "engine_py.py"      },
      { "from": "../render",            "to": "render"            },
      { "from": "../puzzle.html",       "to": "puzzle.html"       }
    ],
    "mac": {
      "category": "public.app-category.games",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ],
      "darkModeSupport": true,
      "extraResources": [
        { "from": "../chess_engine",  "to": "chess_engine"  },
        { "from": "../puzzle_engine", "to": "puzzle_engine" }
      ]
    },
    "win": {
      "target": "nsis",
      "extraResources": [
        { "from": "../chess_engine.exe",  "to": "chess_engine.exe"  },
        { "from": "../puzzle_engine.exe", "to": "puzzle_engine.exe" }
      ]
    },
    "linux": {
      "target": "AppImage",
      "extraResources": [
        { "from": "../chess_engine",  "to": "chess_engine"  },
        { "from": "../puzzle_engine", "to": "puzzle_engine" }
      ]
    },
    "dmg": {
      "title": "ND Chess",
      "background": null,
      "window": { "width": 540, "height": 380 }
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0"
  }
}

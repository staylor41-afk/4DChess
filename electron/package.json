{
  "name": "8d-chess",
  "version": "45.70.0",
  "description": "8D Chess by Samuel M G Taylor",
  "author": "Samuel M G Taylor",
  "main": "main.js",
  "scripts": {
    "start": "electron . --enable-logging",
    "build-win": "electron-builder --win",
    "build-mac": "electron-builder --mac",
    "build-linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.samueltaylor.8dchess",
    "productName": "8D Chess",
    "files": [
      "main.js",
      "preload.js",
      "CODEX-ENGINE-SPEC.md"
    ],
    "extraResources": [
      { "from": "../render",     "to": "render" },
      { "from": "../8d-chess-v45.70-diplomacy-comms-visible.html", "to": "8d-chess-v45.70-diplomacy-comms-visible.html" },
      { "from": "../chess_engine.exe", "to": "chess_engine.exe", "filter": ["**/*"] },
      { "from": "../chess_engine",     "to": "chess_engine",     "filter": ["**/*"] }
    ],
    "win": { "target": "nsis" },
    "mac": { "target": "dmg"  },
    "linux": { "target": "AppImage" }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
